# 기본: 텍스트 파일은 LF로 통일
* text=auto eol=lf

# 명시적 LF
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sql text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
gradlew text eol=lf

# 윈도우 전용 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 바이너리 (변환 안 함)
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
